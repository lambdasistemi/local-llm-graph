<https://github.com/lambdasistemi/local-llm-graph/rdf/node/tokens/link/0> <https://lambdasistemi.github.io/graph-browser/vocab/terms#url> "https://platform.openai.com/tokenizer"^^<http://www.w3.org/2001/XMLSchema#anyURI> ;
	<http://www.w3.org/2000/01/rdf-schema#label> "OpenAI Tokenizer" ;
	a <https://lambdasistemi.github.io/graph-browser/vocab/terms#ExternalLink> .
<https://github.com/lambdasistemi/local-llm-graph/rdf/node/tokens> <https://lambdasistemi.github.io/graph-browser/vocab/terms#description> "The basic units of text that LLMs process. Text is split into tokens by a tokenizer — roughly 1 token per 0.75 English words, though code is often denser (more tokens per line). A 128K context window means 128,000 tokens. Inference speed is measured in tokens per second (tok/s). API pricing is per token (input and output counted separately)." ;
	<https://lambdasistemi.github.io/graph-browser/vocab/terms#group> <https://lambdasistemi.github.io/graph-browser/vocab/groups#concepts> ;
	<http://www.w3.org/2000/01/rdf-schema#label> "Tokens" ;
	<https://lambdasistemi.github.io/graph-browser/vocab/terms#nodeId> "tokens" ;
