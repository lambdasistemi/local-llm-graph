	a <https://lambdasistemi.github.io/graph-browser/vocab/kinds#hub> , <https://lambdasistemi.github.io/graph-browser/vocab/terms#Node> .
<https://github.com/lambdasistemi/local-llm-graph/rdf/node/gpu> <https://lambdasistemi.github.io/graph-browser/vocab/terms#externalLink> <https://github.com/lambdasistemi/local-llm-graph/rdf/node/gpu/link/0> .
<https://github.com/lambdasistemi/local-llm-graph/rdf/node/gpu/link/0> <https://lambdasistemi.github.io/graph-browser/vocab/terms#url> "https://blogs.nvidia.com/blog/why-gpus-are-great-for-ai/"^^<http://www.w3.org/2001/XMLSchema#anyURI> ;
	<http://www.w3.org/2000/01/rdf-schema#label> "Why GPUs for AI" ;
	a <https://lambdasistemi.github.io/graph-browser/vocab/terms#ExternalLink> .
<https://github.com/lambdasistemi/local-llm-graph/rdf/node/gpu> <https://lambdasistemi.github.io/graph-browser/vocab/terms#description> "Massively parallel processors originally for graphics, now essential for AI. GPUs excel at matrix multiplication — the core operation in transformer inference. Key specs: VRAM (how much model fits), memory bandwidth (determines tok/s), and compute (TFLOPS, determines prefill speed). Discrete GPUs (NVIDIA RTX, AMD Radeon) have dedicated VRAM; integrated GPUs (like Strix Halo) share system memory." ;
	<https://lambdasistemi.github.io/graph-browser/vocab/terms#group> <https://lambdasistemi.github.io/graph-browser/vocab/groups#concepts> ;
	<http://www.w3.org/2000/01/rdf-schema#label> "GPU (Graphics Processing Unit)" ;
	<https://lambdasistemi.github.io/graph-browser/vocab/terms#nodeId> "gpu" ;
	<http://purl.org/dc/terms/isPartOf> <https://github.com/lambdasistemi/local-llm-graph/rdf> ;
	a <https://lambdasistemi.github.io/graph-browser/vocab/kinds#concept> , <https://lambdasistemi.github.io/graph-browser/vocab/terms#Node> .
