<https://github.com/lambdasistemi/local-llm-graph/rdf/node/gptq/link/0> <https://lambdasistemi.github.io/graph-browser/vocab/terms#url> "https://arxiv.org/abs/2210.17323"^^<http://www.w3.org/2001/XMLSchema#anyURI> ;
	<http://www.w3.org/2000/01/rdf-schema#label> "Paper" ;
	a <https://lambdasistemi.github.io/graph-browser/vocab/terms#ExternalLink> .
<https://github.com/lambdasistemi/local-llm-graph/rdf/node/gptq> <https://lambdasistemi.github.io/graph-browser/vocab/terms#description> "Post-training quantization method that uses approximate second-order information for weight compression. Typically INT4 or INT8. Requires calibration data. Supported by vLLM, HuggingFace Transformers, AutoGPTQ. More GPU-centric than GGUF — optimized for CUDA tensor cores." ;
	<https://lambdasistemi.github.io/graph-browser/vocab/terms#group> <https://lambdasistemi.github.io/graph-browser/vocab/groups#quantization> ;
	<http://www.w3.org/2000/01/rdf-schema#label> "GPTQ" ;
