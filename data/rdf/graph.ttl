	<http://www.w3.org/2000/01/rdf-schema#label> "Paper" ;
	a <https://lambdasistemi.github.io/graph-browser/vocab/terms#ExternalLink> .
<https://github.com/lambdasistemi/local-llm-graph/rdf/node/aqlm> <https://lambdasistemi.github.io/graph-browser/vocab/terms#description> "Additive Quantization of Language Models. Multi-codebook approach dividing weight vectors into sub-vectors approximated by codewords. State-of-the-art quality at 2 bits per weight. Outperforms GPTQ and QuIP# at extreme compression levels." ;
	<https://lambdasistemi.github.io/graph-browser/vocab/terms#group> <https://lambdasistemi.github.io/graph-browser/vocab/groups#quantization> ;
