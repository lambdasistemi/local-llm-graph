	<http://purl.org/dc/terms/isPartOf> <https://github.com/lambdasistemi/local-llm-graph/rdf> ;
	a <https://lambdasistemi.github.io/graph-browser/vocab/kinds#assistant> , <https://lambdasistemi.github.io/graph-browser/vocab/terms#Node> .
<https://github.com/lambdasistemi/local-llm-graph/rdf/node/codestral> <https://lambdasistemi.github.io/graph-browser/vocab/terms#externalLink> <https://github.com/lambdasistemi/local-llm-graph/rdf/node/codestral/link/0> .
<https://github.com/lambdasistemi/local-llm-graph/rdf/node/codestral/link/0> <https://lambdasistemi.github.io/graph-browser/vocab/terms#url> "https://mistral.ai/news/codestral/"^^<http://www.w3.org/2001/XMLSchema#anyURI> ;
	<http://www.w3.org/2000/01/rdf-schema#label> "Mistral" ;
	a <https://lambdasistemi.github.io/graph-browser/vocab/terms#ExternalLink> .
<https://github.com/lambdasistemi/local-llm-graph/rdf/node/codestral> <https://lambdasistemi.github.io/graph-browser/vocab/terms#description> "Mistral's 22B code model. 32K context. HumanEval ~81%. Strong across many programming languages. ~14GB at Q4_K_M. Efficient and fast. License was initially non-commercial — verify current terms." ;
	<https://lambdasistemi.github.io/graph-browser/vocab/terms#group> <https://lambdasistemi.github.io/graph-browser/vocab/groups#code-models> ;
