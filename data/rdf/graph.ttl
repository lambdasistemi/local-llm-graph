	<http://www.w3.org/2000/01/rdf-schema#label> "Website" ;
	a <https://lambdasistemi.github.io/graph-browser/vocab/terms#ExternalLink> .
<https://github.com/lambdasistemi/local-llm-graph/rdf/node/unsloth> <https://lambdasistemi.github.io/graph-browser/vocab/terms#description> "Known for Dynamic 2.0 GGUFs — an improved quantization methodology using calibration datasets. Also provides fine-tuning tools. Active competitor to bartowski. Releases 25+ GGUF variants per major model. Dynamic 2.0 works on all models including MoEs." ;
	<https://lambdasistemi.github.io/graph-browser/vocab/terms#group> <https://lambdasistemi.github.io/graph-browser/vocab/groups#distribution> ;
