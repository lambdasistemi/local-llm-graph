<https://github.com/lambdasistemi/local-llm-graph/rdf/node/awq/link/0> <https://lambdasistemi.github.io/graph-browser/vocab/terms#url> "https://arxiv.org/abs/2306.00978"^^<http://www.w3.org/2001/XMLSchema#anyURI> ;
	<http://www.w3.org/2000/01/rdf-schema#label> "Paper" ;
	a <https://lambdasistemi.github.io/graph-browser/vocab/terms#ExternalLink> .
<https://github.com/lambdasistemi/local-llm-graph/rdf/node/awq> <https://lambdasistemi.github.io/graph-browser/vocab/terms#description> "Activation-aware Weight Quantization. Preserves salient weight channels identified by activation magnitudes. Typically INT4. Supported by vLLM, TensorRT-LLM, HuggingFace. Often slightly better quality than GPTQ at same bit width for instruction-following tasks." ;
	<https://lambdasistemi.github.io/graph-browser/vocab/terms#group> <https://lambdasistemi.github.io/graph-browser/vocab/groups#quantization> ;
