@prefix gb: <https://lambdasistemi.github.io/graph-browser/vocab/terms#> .
@prefix gbkind: <https://lambdasistemi.github.io/graph-browser/vocab/kinds#> .
@prefix gbgroup: <https://lambdasistemi.github.io/graph-browser/vocab/groups#> .
@prefix gbedge: <https://lambdasistemi.github.io/graph-browser/vocab/edges#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix dcterms: <http://purl.org/dc/terms/> .

<https://lambdasistemi.github.io/graph-browser/vocab/application-ontology> a owl:Ontology ;
  rdfs:label "Graph Browser application vocabulary" ;
  dcterms:description "Repository-specific vocabulary generated from graph-browser config and graph data." ;
  owl:imports <https://lambdasistemi.github.io/graph-browser/vocab/ontology> ;
  owl:versionInfo "0.1.0" .

gbkind:assistant a owl:Class ;
  rdfs:label "Coding Assistant" ;
  gb:kindId "assistant" ;
  gb:color "#f778ba" ;
  gb:shape "round-octagon" ;
  rdfs:subClassOf gb:Node .

gbkind:concept a owl:Class ;
  rdfs:label "Concept" ;
  gb:kindId "concept" ;
  gb:color "#56d364" ;
  gb:shape "star" ;
  rdfs:subClassOf gb:Node .

gbkind:engine a owl:Class ;
  rdfs:label "Inference Engine" ;
  gb:kindId "engine" ;
  gb:color "#3fb950" ;
  gb:shape "round-rectangle" ;
  rdfs:subClassOf gb:Node .

gbkind:format a owl:Class ;
  rdfs:label "Quantization Format" ;
  gb:kindId "format" ;
  gb:color "#d2a8ff" ;
  gb:shape "diamond" ;
  rdfs:subClassOf gb:Node .

gbkind:hardware a owl:Class ;
  rdfs:label "Hardware / Backend" ;
  gb:kindId "hardware" ;
  gb:color "#79c0ff" ;
  gb:shape "barrel" ;
  rdfs:subClassOf gb:Node .

gbkind:hub a owl:Class ;
  rdfs:label "Model Hub / Quantizer" ;
  gb:kindId "hub" ;
  gb:color "#e3b341" ;
  gb:shape "round-pentagon" ;
  rdfs:subClassOf gb:Node .

gbkind:model a owl:Class ;
  rdfs:label "Model" ;
  gb:kindId "model" ;
  gb:color "#f0883e" ;
  gb:shape "ellipse" ;
  rdfs:subClassOf gb:Node .

gbkind:protocol a owl:Class ;
  rdfs:label "API Protocol" ;
  gb:kindId "protocol" ;
  gb:color "#8b949e" ;
  gb:shape "rectangle" ;
  rdfs:subClassOf gb:Node .

gbkind:proxy a owl:Class ;
  rdfs:label "API Proxy / Router" ;
  gb:kindId "proxy" ;
  gb:color "#58a6ff" ;
  gb:shape "round-hexagon" ;
  rdfs:subClassOf gb:Node .


gbgroup:assistants a gb:Group ;
  rdfs:label "assistants" ;
  gb:groupId "assistants" .

gbgroup:code-models a gb:Group ;
  rdfs:label "code-models" ;
  gb:groupId "code-models" .

gbgroup:concepts a gb:Group ;
  rdfs:label "concepts" ;
  gb:groupId "concepts" .

gbgroup:distribution a gb:Group ;
  rdfs:label "distribution" ;
  gb:groupId "distribution" .

gbgroup:engines a gb:Group ;
  rdfs:label "engines" ;
  gb:groupId "engines" .

gbgroup:general-models a gb:Group ;
  rdfs:label "general-models" ;
  gb:groupId "general-models" .

gbgroup:hardware a gb:Group ;
  rdfs:label "hardware" ;
  gb:groupId "hardware" .

gbgroup:protocols a gb:Group ;
  rdfs:label "protocols" ;
  gb:groupId "protocols" .

gbgroup:proxies a gb:Group ;
  rdfs:label "proxies" ;
  gb:groupId "proxies" .

gbgroup:quantization a gb:Group ;
  rdfs:label "quantization" ;
  gb:groupId "quantization" .

gbgroup:reasoning-models a gb:Group ;
  rdfs:label "reasoning-models" ;
  gb:groupId "reasoning-models" .


